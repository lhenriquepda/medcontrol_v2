<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="${appLabel}"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="${appLabel}"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep links: dosy-teal.vercel.app HTTPS + custom scheme -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="dosy-teal.vercel.app" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="dosy" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- AdMob App ID — Dosy production. Required by MobileAdsInitProvider. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-2350865861527931~5445284437"
        />

        <!-- Alarme Crítico: Activity full-screen + Receiver -->
        <!-- v0.2.3.1 B-03: removido android:showOnLockScreen (atributo invalido nao-spec).
             showWhenLocked + turnScreenOn (Android 8.1+) cobrem corretamente. -->
        <activity
            android:name=".plugins.criticalalarm.AlarmActivity"
            android:exported="false"
            android:turnScreenOn="true"
            android:showWhenLocked="true"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen"
        />

        <receiver android:name=".plugins.criticalalarm.AlarmReceiver" android:exported="false" android:enabled="true" />
        <receiver
            android:name=".plugins.criticalalarm.AlarmActionReceiver"
            android:exported="false"
            android:enabled="true"
        />
        <!-- #215 v0.2.3.0 — TrayNotificationReceiver dispara LocalNotification tray
             pra branches PUSH_CRITICAL_OFF + PUSH_DND + backup ALARM_PLUS_PUSH -->
        <receiver
            android:name=".plugins.criticalalarm.TrayNotificationReceiver"
            android:exported="false"
            android:enabled="true"
        />

        <service
            android:name=".plugins.criticalalarm.AlarmService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="medication_reminder" />
        </service>

        <!-- Item #083.5 (release v0.1.7.2) — DosyMessagingService intercepta
             FCM data messages com action "schedule_alarms".
             Estende com.capacitorjs.plugins.pushnotifications.MessagingService:
             onNewToken delega pra super (Capacitor recebe tokens normal),
             onMessageReceived processa schedule_alarms ou delega pra super.

             Removemos service Capacitor default via tools:node="remove" pra
             garantir nosso service único receba dispatches FCM (Firebase
             routing escolhe primeiro registrado quando há dois). -->
        <service android:name="com.capacitorjs.plugins.pushnotifications.MessagingService" tools:node="remove" />
        <service android:name=".plugins.criticalalarm.DosyMessagingService" android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver android:name=".plugins.criticalalarm.BootReceiver" android:exported="true" android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Notificações (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Alarmes EXATOS para horários de dose (medicação = categoria aprovada pela Play Store) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Re-agendar alarmes após reboot do device -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Manter device acordado durante notif (alarmes confiáveis) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibração -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Alarme Crítico — full-screen sobre lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Bypass DND (modo Não Perturbe) — requer user grant em Settings -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Acordar device pra alarme -->
    <uses-permission android:name="android.permission.TURN_SCREEN_ON" />
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />

    <!-- Foreground service pra lançar AlarmActivity (BAL workaround Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- BAL exemption: permite startActivity de background quando granted -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Item #207 (release v0.2.1.7) — bypass battery optimization Doze/App Standby.
         CRÍTICO Samsung One UI 7 + Xiaomi MIUI: sem isso OEM coloca app em bucket
         "rare/restricted" → kills WorkManager periodic + cancela alarms agendados.
         Play Store policy permite pra apps de medicação ("alarm clock or medication
         reminder" em Use of REQUEST_IGNORE_BATTERY_OPTIMIZATIONS exception). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
</manifest>
