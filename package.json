{
  "name": "medcontrol",
  "private": true,
  "version": "0.2.1.1",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:android": "npm run build && npx cap sync android",
    "open:android": "npx cap open android",
    "cap:sync": "npx cap sync",
    "lint": "eslint src --max-warnings=80",
