# Dosy — Variáveis de ambiente
# Copie para .env.local e preencha com valores reais.
# NUNCA commitar .env ou .env.local no git.

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
VITE_SUPABASE_SCHEMA=medcontrol

# ── Web Push VAPID ────────────────────────────────────────────────────────────
# Frontend usa apenas a PUBLIC key
VITE_VAPID_PUBLIC_KEY=sua_vapid_public_key_aqui
# VAPID_PRIVATE_KEY → somente como secret no painel Supabase (Edge Functions → Secrets)
# NUNCA colocar aqui ou no frontend

# ── Google AdSense (opcional — web only, deixar vazio em dev) ───────────────
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT=

# ── AdMob (opcional — Android nativo) ────────────────────────────────────────
# Test ID padrão; em produção usar real ad unit ID do AdMob console
VITE_ADMOB_BANNER_ANDROID=

# ── Sentry (opcional — monitoramento de erros em produção) ───────────────────
VITE_SENTRY_DSN=

# ── Firebase (Fase 2 — Edge Function notify-doses) ───────────────────────────
# Configurar como secrets no painel Supabase, não aqui
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY= → somente como secret Supabase
